{
  "manifest_version": 3,
  "name": "MotifLab for Suno",
  "version": "0.1.4",
  "description": "在 Suno 使用過程中查看、編輯與複製 MotifLab 的創作結論詞。",
  "permissions": ["storage", "clipboardWrite", "activeTab", "scripting"],
  "host_permissions": [
    "https://suno.com/*",
    "https://*.suno.com/*",
    "https://suno.ai/*",
    "https://*.suno.ai/*"
  ],
  "action": {
    "default_title": "MotifLab for Suno",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://suno.com/*",
        "https://*.suno.com/*",
        "https://suno.ai/*",
        "https://*.suno.ai/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ]
}
